# LLM provider — pick one:
# Fireworks (recommended, higher free tier limits):
# FIREWORKS_API_KEY="fw_..."
# Groq (100K tokens/day free tier):
# GROQ_API_KEY="gsk_..."

# Optional — without this, Slack notifications silently no-op:
# SYN_SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# Rate limiting (applied per client IP across all endpoints, /health excluded)
# SYN_RATE_LIMIT: max requests allowed per window (default 100)
# SYN_RATE_WINDOW_SECONDS: sliding window length in seconds (default 60)
# SYN_RATE_LIMIT="100"
# SYN_RATE_WINDOW_SECONDS="60"

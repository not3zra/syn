# ── LLM Provider ──────────────────────────────────────────
# All providers (local | openai | groq | fireworks | mock)
# use the same LLM_* environment variables.
LLM_PROVIDER=mock
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=...
# LLM_MODEL=...
# LLM_TIMEOUT=15
# LLM_MAX_RETRIES=2
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=3000

# ── Per-provider API keys (fallback chain) ────────────────
# GROQ_API_KEY=gsk_...
# FIREWORKS_API_KEY=...
# OPENAI_API_KEY=sk-...

# ── Slack (escalation notifications) ──────────────────────
# SYN_SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# ── Rate Limiting ─────────────────────────────────────────
# Applied per client IP across all endpoints (/health excluded)
# SYN_RATE_LIMIT=100
# SYN_RATE_WINDOW_SECONDS=60

# ── Request Limits ────────────────────────────────────────
# SYN_MAX_BODY_SIZE=1048576

# ── CORS ──────────────────────────────────────────────────
# SYN_ALLOW_ORIGINS="*"
# FRONTEND_URL="https://syn.onrender.com"

# ── Audit Database ────────────────────────────────────────
# SYN_AUDIT_DB_PATH=data/audit.db
# SYN_AUDIT_RETENTION_DAYS=90

# ── Trusted Proxy (rate limiter) ──────────────────────────
# SYN_TRUSTED_PROXY=false

# ── Demo Token (required on production deploy) ────────────
# DEMO_TOKEN="..."
# DEPLOY_ENV=production

# ── Frontend ──────────────────────────────────────────────
# VITE_DEMO_TOKEN="..."   # Must match DEMO_TOKEN; inlined into the JS bundle
# VITE_API_BASE=""        # Custom API base URL for the frontend

# LLM provider — pick one: local | openai | groq | fireworks | mock
# All providers use the same LLM_* environment variables.
LLM_PROVIDER=mock
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=...
# LLM_MODEL=...
# LLM_TIMEOUT=15
# LLM_MAX_RETRIES=2
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=3000

# Per-provider API keys (used by fallback chain when primary fails):
# GROQ_API_KEY=gsk_...
# FIREWORKS_API_KEY=...
# OPENAI_API_KEY=sk-...

# Optional — without this, Slack notifications silently no-op:
# SYN_SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# Rate limiting (applied per client IP across all endpoints, /health excluded)
# SYN_RATE_LIMIT: max requests allowed per window (default 100)
# SYN_RATE_WINDOW_SECONDS: sliding window length in seconds (default 60)
# SYN_RATE_LIMIT="100"
# SYN_RATE_WINDOW_SECONDS="60"

# Frontend build-time environment (Vite inlines VITE_* vars at build time).
# Copy to `.env` for local dev, or pass as Docker build args.

# Public demo tripwire token (#34). Baked into the client bundle and sent as
# the X-Demo-Token header on every mutating request. This is NOT real auth —
# it only gates the public demo. Leave unset for local dev (no header sent).
VITE_DEMO_TOKEN=

# Base URL for the backend API. Leave empty to use same-origin / the Vite dev
# proxy (recommended for local dev). Set to e.g. https://api.example.com in
# deployments where the API is on a different origin.
VITE_API_BASE=
